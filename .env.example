# ── AICE 모의고사 연동용 환경변수 예시 ──
# 로컬: 이 파일을 .env 로 복사해 값 채우기 (또는 `vercel env pull .env`)
# 배포: Vercel > Project > Settings > Environment Variables 에 등록

# DB (Vercel Postgres 연결 시 자동 주입됨. 로컬은 vercel env pull 로 내려받기)
POSTGRES_URL=

# aicoach 서버-서버 인증용 파트너 API 키 (세션 생성/토큰/결과 조회 호출 인증)
PARTNER_API_KEY=

# 결과 웹훅 HMAC 서명 키 (aicoach와 공유하는 파트너 비밀키)
WEBHOOK_SECRET=

# 일회용 진입(Launch) 토큰 서명 키
LAUNCH_TOKEN_SECRET=

# (기존) LLM/이미지/로그인 — 이미 사용 중이면 그대로 유지
OPENAI_API_KEY=
GOOGLE_API_KEY=
ACCESS_PASSWORD=
